# Normalize line endings — text files use LF in repo, native EOL in working tree.
# Suppresses the CRLF warning storm on Windows checkouts.
* text=auto eol=lf

# Markdown and PowerShell are text — LF in repo
*.md     text eol=lf
*.ps1    text eol=lf
*.sh     text eol=lf
*.mdc    text eol=lf
*.json   text eol=lf
*.yaml   text eol=lf
*.yml    text eol=lf

# Binary — never touch
*.png    binary
*.jpg    binary
*.gif    binary
*.ico    binary
*.zip    binary
